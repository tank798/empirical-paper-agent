generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String              @id @default(uuid())
  title           String
  topicRaw        String              @map("topic_raw")
  topicNormalized String?             @map("topic_normalized")
  currentStep     String              @map("current_step")
  status          String
  researchSummary String?             @map("research_summary")
  lastSkillName   String?             @map("last_skill_name")
  resumeTokenHash String              @map("resume_token_hash")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  steps           ProjectStep[]
  messages        Message[]
  researchProfile ResearchProfile?
  skillRuns       SkillRun[]
  agentRuns       AgentRun[]
  agentEvents     AgentEvent[]
  agentToolResults AgentToolResult[]
  agentArtifacts  AgentArtifact[]
  codeBlocks      CodeBlock[]
  exportState     ProjectExportState?
  exports         Export[]

  @@map("projects")
}

model ProjectStep {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  step        String
  status      String
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  metadataJson Json     @default("{}") @map("metadata_json")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, step])
  @@map("project_steps")
}

model Message {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  role        String
  messageType String    @map("message_type")
  step        String?
  contentText String?   @map("content_text")
  contentJson Json      @map("content_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model ResearchProfile {
  id                  String   @id @default(uuid())
  projectId           String   @unique @map("project_id")
  normalizedTopic     String   @default("") @map("normalized_topic")
  independentVariable String   @default("") @map("independent_variable")
  dependentVariable   String   @default("") @map("dependent_variable")
  researchObject      String   @default("") @map("research_object")
  relationship        String   @default("")
  controls            String[] @default([])
  fixedEffects        String[] @default([]) @map("fixed_effects")
  clusterVar          String?  @map("cluster_var")
  panelId             String?  @map("panel_id")
  timeVar             String?  @map("time_var")
  sampleScope         String?  @map("sample_scope")
  analysisRoute       String   @default("panel_fe") @map("analysis_route")
  didEnabled          Boolean  @default(false) @map("did_enabled")
  psmEnabled          Boolean  @default(false) @map("psm_enabled")
  treatmentVar        String?  @map("treatment_var")
  policyTimeVar       String?  @map("policy_time_var")
  policyStartYear     String?  @map("policy_start_year")
  instrumentVariable  String?  @map("instrument_variable")
  psmMatchVars        String[] @default([]) @map("psm_match_vars")
  mechanismVariables  String[] @default([]) @map("mechanism_variables")
  heterogeneityVars   String[] @default([]) @map("heterogeneity_vars")
  exportFormats       String[] @default([]) @map("export_formats")
  notes               String?
  dataDictionaryJson  Json     @default("[]") @map("data_dictionary_json")
  termMappingsJson    Json     @default("[]") @map("term_mappings_json")
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("research_profiles")
}

model SkillRun {
  id            String   @id @default(uuid())
  projectId      String   @map("project_id")
  skillName      String   @map("skill_name")
  step           String
  inputJson      Json     @map("input_json")
  outputJson     Json?    @map("output_json")
  errorJson      Json?    @map("error_json")
  promptVersion  String   @map("prompt_version")
  model          String
  status         String
  createdAt      DateTime @default(now()) @map("created_at")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("skill_runs")
}

model AgentRun {
  id               String            @id @default(uuid())
  projectId         String            @map("project_id")
  kind             String
  status           String
  requestedStep    String?           @map("requested_step")
  currentStep      String?           @map("current_step")
  phase            String?
  userMessagePreview String?         @map("user_message_preview")
  progressPercent  Int               @default(0) @map("progress_percent")
  currentCount     Int               @default(0) @map("current_count")
  totalCount       Int               @default(0) @map("total_count")
  stageLabel       String?           @map("stage_label")
  inputJson        Json              @default("{}") @map("input_json")
  outputJson       Json?             @map("output_json")
  errorJson        Json?             @map("error_json")
  startedAt        DateTime?         @map("started_at")
  completedAt      DateTime?         @map("completed_at")
  lastHeartbeatAt  DateTime?         @map("last_heartbeat_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events           AgentEvent[]
  toolResults      AgentToolResult[]
  artifacts        AgentArtifact[]

  @@index([projectId, createdAt])
  @@map("agent_runs")
}

model AgentEvent {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  runId       String?   @map("run_id")
  type        String
  phase       String?
  message     String?
  progressJson Json?    @map("progress_json")
  metadataJson Json     @default("{}") @map("metadata_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run         AgentRun? @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([runId, createdAt])
  @@map("agent_events")
}

model AgentToolResult {
  id                 String    @id @default(uuid())
  projectId           String    @map("project_id")
  runId              String?   @map("run_id")
  toolUseId          String?   @map("tool_use_id")
  toolName           String    @map("tool_name")
  step               String?
  status             String
  permissionDecision String    @map("permission_decision")
  inputJson          Json      @default("{}") @map("input_json")
  outputJson         Json?     @map("output_json")
  errorJson          Json?     @map("error_json")
  durationMs         Int?      @map("duration_ms")
  createdAt          DateTime  @default(now()) @map("created_at")
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run                AgentRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([runId, createdAt])
  @@map("agent_tool_results")
}

model AgentArtifact {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  runId          String?   @map("run_id")
  kind           String
  name           String
  mimeType       String?   @map("mime_type")
  sizeBytes      Int?      @map("size_bytes")
  contentPreview String    @default("") @map("content_preview")
  contentText    String?   @map("content_text")
  metadataJson   Json      @default("{}") @map("metadata_json")
  createdAt      DateTime  @default(now()) @map("created_at")
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run            AgentRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([runId, createdAt])
  @@map("agent_artifacts")
}

model CodeBlock {
  id              String   @id @default(uuid())
  projectId        String   @map("project_id")
  moduleName       String   @map("module_name")
  language         String
  code             String
  explanationJson  Json     @map("explanation_json")
  exportCode       String?  @map("export_code")
  createdAt        DateTime @default(now()) @map("created_at")
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("code_blocks")
}

model ProjectExportState {
  id                        String   @id @default(uuid())
  projectId                 String   @unique @map("project_id")
  defaultExportPath         String   @map("default_export_path")
  defaultExportFileName     String   @map("default_export_file_name")
  hasWrittenRegressionTable Boolean  @default(false) @map("has_written_regression_table")
  nextWriteMode             String   @map("next_write_mode")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_export_states")
}

model Export {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  type      String
  fileUrl   String?  @map("file_url")
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("exports")
}
