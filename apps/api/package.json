{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "corepack pnpm --filter @empirical/shared build && corepack pnpm --filter @empirical/prompts build && nest build",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "corepack pnpm --filter @empirical/shared build && corepack pnpm --filter @empirical/prompts build && nest build && node dist/apps/api/src/main.js",
    "lint": "tsc --noEmit",
    "test": "jest --runInBand",
    "smoke:agent-prompt": "ts-node -P tsconfig.json -r ../../node_modules/.pnpm/tsconfig-paths@4.2.0/node_modules/tsconfig-paths/register scripts/agent-prompt-smoke-test.ts",
    "smoke:agent": "ts-node -P tsconfig.json -r ../../node_modules/.pnpm/tsconfig-paths@4.2.0/node_modules/tsconfig-paths/register scripts/agent-smoke-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@empirical/prompts": "workspace:*",
    "@empirical/shared": "workspace:*",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-express": "^11.0.11",
    "@prisma/client": "^6.5.0",
    "openai": "^4.92.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/testing": "^11.0.11",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
